# /etc/authnull/app.env
# Production secrets for the AuthNull AD Gateway.
# Copy to /etc/authnull/app.env and fill in the values below.
# Loaded automatically by both systemd units via EnvironmentFile.
#
# Permissions (set once after install):
#   sudo chown root:authnull /etc/authnull/app.env
#   sudo chmod 640 /etc/authnull/app.env

# ----------------------------------------------------------------------------
# AuthNull cloud — control plane (ad-gateway-control)
# ----------------------------------------------------------------------------

# MFA push endpoint. Prod URL is fixed; change only if you're on a dev tenant.
AUTHNULL_BASE_URL=https://prod.api.authnull.com/authnull0/api/v1/authn/v3/do-authenticationV4

# AD SAM account names are bare (e.g. "sathyam"); append this domain to form
# the wallet username ("sathyam@your-domain.com").
AUTHNULL_EMAIL_DOMAIN=

# Org and tenant IDs from your AuthNull tenant dashboard.
AUTHNULL_ORG_ID=
AUTHNULL_TENANT_ID=

# AD bind password for the optional unlock-account action.
# Only needed if you set ad.ldap_url in control.yml.
AD_BIND_PW=

# ----------------------------------------------------------------------------
# AuthNull cloud — uplink (ad-gateway-proxy → ad-service audit ingest)
# ----------------------------------------------------------------------------

# Audit ingest endpoint. Prod URL is fixed.
AUTHNULL_UPLINK_URL=https://prod.api.authnull.com/ad/IngestGatewayAuthEvents
