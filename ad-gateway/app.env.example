# /etc/authnull/app.env
# Secrets and service URLs for the AuthNull AD Gateway.
# Generated by the AuthNull UI (Add Gateway wizard) or filled in manually.
# Loaded automatically by both systemd units via EnvironmentFile.
#
# Permissions (set once after install):
#   sudo chown root:authnull /etc/authnull/app.env
#   sudo chmod 640 /etc/authnull/app.env

# ----------------------------------------------------------------------------
# AuthNull service endpoints
# Both point to the same API gateway — routing is by path.
# ----------------------------------------------------------------------------
AD_SERVICE_URL=https://dev.api.authnull.com
POLICY_SERVICE_URL=https://dev.api.authnull.com
AUTHNULL_UPLINK_URL=https://dev.api.authnull.com

# ----------------------------------------------------------------------------
# Tenant scoping — from your AuthNull tenant dashboard
# ----------------------------------------------------------------------------
AD_ORG_ID=
AD_TENANT_ID=

# ----------------------------------------------------------------------------
# AD user sync
# The gateway syncs AD users to AuthNull on a schedule (default: every 10 min).
# ----------------------------------------------------------------------------
AD_SYNC_LDAP_URL=ldap://10.4.0.17:389        # or ldaps://... for port 636
AD_SYNC_BIND_DN=CN=AuthNullSvc,CN=Users,DC=authnull,DC=lab
AD_SYNC_BASE_DN=DC=authnull,DC=lab
AD_SYNC_DOMAIN_ID=                            # numeric domain ID from AuthNull UI
AD_SYNC_INTERVAL_MINUTES=10
AD_SYNC_INSECURE_SKIP_VERIFY=false            # set true only for self-signed lab certs

# Sync scope — leave blank to sync all users.
# Groups: comma-separated plain group names, e.g. Domain Admins,VPN-Users
# OUs:    comma-separated OU fragments,    e.g. OU=AdminUsers,OU=ITStaff
AD_SYNC_FILTER_GROUPS=
AD_SYNC_FILTER_OUS=

# Service account bind password — entered during install.sh, never sent to AuthNull.
AD_SYNC_BIND_PW=
